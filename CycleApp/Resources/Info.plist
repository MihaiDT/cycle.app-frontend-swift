<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Cycle</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Cycle uses your camera to capture photos for daily challenges.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Cycle accesses your photo library so you can choose photos for daily challenges.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Cycle uses your health data to provide personalized cycle insights, track patterns, and help you understand your body better.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Cycle can log your cycle data to Apple Health, keeping all your health information in one place.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>UIAppFonts</key>
	<array>
		<string>Raleway-Regular.ttf</string>
		<string>Raleway-Bold.ttf</string>
		<string>Raleway-SemiBold.ttf</string>
		<string>Raleway-Medium.ttf</string>
		<string>Raleway-Light.ttf</string>
		<string>Raleway-Thin.ttf</string>
		<string>Raleway-ExtraLight.ttf</string>
		<string>Raleway-ExtraBold.ttf</string>
		<string>Raleway-Black.ttf</string>
		<string>Raleway-Italic.ttf</string>
		<string>Raleway-BoldItalic.ttf</string>
		<string>Raleway-SemiBoldItalic.ttf</string>
		<string>Raleway-MediumItalic.ttf</string>
		<string>Raleway-LightItalic.ttf</string>
		<string>Raleway-ThinItalic.ttf</string>
		<string>Raleway-ExtraLightItalic.ttf</string>
		<string>Raleway-ExtraBoldItalic.ttf</string>
		<string>Raleway-BlackItalic.ttf</string>
	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIImageName</key>
		<string>SplashBackground</string>
	</dict>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
